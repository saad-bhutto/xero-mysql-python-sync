# Xero OAuth2 Configuration
# Create a Xero app at https://developer.xero.com/myapps to get these values
XERO_CLIENT_ID=YOUR_XERO_CLIENT_ID_HERE
XERO_CLIENT_SECRET=YOUR_XERO_CLIENT_SECRET_HERE
XERO_REDIRECT_URI=http://localhost:7071/api/auth/callback

# Xero Webhook Key (optional, for webhook signature verification)
XERO_WEBHOOK_KEY=YOUR_XERO_WEBHOOK_KEY_HERE

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xero_sync
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Sync Configuration
SYNC_LOOKBACK_DAYS=60
